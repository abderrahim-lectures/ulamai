# Copy to .env and fill in your real keys. .env is gitignored; never commit
# real keys/secrets. ulam.sh auto-sources .env if present. This file lists
# every environment variable ulam actually reads (grepped from the source),
# pre-filled with ulam's own built-in defaults where one exists -- so most
# lines here are documentation, not required changes. Leave a value blank
# to use ulam's built-in default; secrets are left blank on purpose (no
# "best" secret value).

# --- LLM providers: API keys (no default -- required for that provider) ---
ULAM_OPENAI_API_KEY=
ULAM_ANTHROPIC_API_KEY=
ULAM_ANTHROPIC_SETUP_TOKEN=
ULAM_GEMINI_API_KEY=
# Also accepted as a fallback for ULAM_GEMINI_API_KEY:
GEMINI_API_KEY=
ULAM_EMBED_API_KEY=

# --- LLM providers: base URLs (only change for proxies/self-hosted-compatible endpoints) ---
ULAM_OPENAI_BASE_URL=https://api.openai.com
ULAM_ANTHROPIC_BASE_URL=https://api.anthropic.com
ULAM_OLLAMA_BASE_URL=http://localhost:11434
ULAM_EMBED_BASE_URL=https://api.openai.com

# --- LLM providers: models (ulam's built-in defaults) ---
ULAM_OPENAI_MODEL=gpt-4.1
ULAM_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
ULAM_GEMINI_MODEL=gemini-3.1-pro-preview
ULAM_OLLAMA_MODEL=qwen2.5-coder:7b
ULAM_EMBED_MODEL=text-embedding-3-small

# --- Subscription-CLI model suggestion lists (comma-separated; shown in the
#     interactive menu's model picker, not required for CLI-flag usage) ---
ULAM_CODEX_MODELS=
ULAM_CLAUDE_MODELS=
ULAM_GEMINI_MODELS=

# --- Gemini OAuth (only for `ulam auth gemini`'s browser login flow) ---
ULAM_GEMINI_OAUTH_CLIENT_ID=
ULAM_GEMINI_OAUTH_CLIENT_SECRET=
ULAM_GEMINI_OAUTH2_JS=
OAUTH_CALLBACK_HOST=localhost
# Leave blank: ulam auto-picks a free local port when unset.
OAUTH_CALLBACK_PORT=
NO_BROWSER=

# --- Codex CLI ---
CODEX_HOME=~/.codex

# --- ulam config file location ---
# Full override of the config file path (takes precedence over ULAM_CONFIG_DIR)
ULAM_CONFIG=
ULAM_CONFIG_DIR=.ulam

# --- Lean / dojo backend ---
# Default Lean project root (overridden by --lean-project). Use an
# ABSOLUTE path (not a relative one) -- ulam may be invoked from any
# working directory, and a relative path would resolve against whatever
# that cwd happens to be. E.g. for this repo's own Mathlib-backed example
# project (verified working with dojo): /path/to/ulamai/examples
ULAM_LEAN_PROJECT=
ULAM_DOJO_TIMEOUT_S=180
ULAM_AUTO_INSTALL_PANTOGRAPH=1
ULAM_PANTOGRAPH_QUIET=1
# Only set to 1 if pip refuses to install on a PEP 668 "externally managed"
# system Python -- not needed with the uv-managed .venv this repo uses.
ULAM_BREAK_SYSTEM_PACKAGES=0
# Extra Lean elaborator options passed through to the Lean process (rarely needed).
LEAN_OPTIONS=
LEAN_CORE_OPTIONS=

# --- formalize pipeline ---
ULAM_FORMALIZE_LOCAL_RETRIEVER=1
